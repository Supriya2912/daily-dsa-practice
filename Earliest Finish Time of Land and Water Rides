# ☕ Java Solution

```java
class Solution {

    public int earliestFinishTime(int[] lst, int[] ldu,
                                  int[] wst, int[] wdu) {

        int ans = Integer.MAX_VALUE;
        int minLand = Integer.MAX_VALUE;
        int minWater = Integer.MAX_VALUE;

        for (int i = 0; i < lst.length; i++) {
            minLand = Math.min(minLand,
                               lst[i] + ldu[i]);
        }

        for (int i = 0; i < wst.length; i++) {
            ans = Math.min(ans,
                           Math.max(minLand, wst[i]) + wdu[i]);
        }

        for (int i = 0; i < wst.length; i++) {
            minWater = Math.min(minWater,
                                wst[i] + wdu[i]);
        }

        for (int i = 0; i < lst.length; i++) {
            ans = Math.min(ans,
                           Math.max(minWater, lst[i]) + ldu[i]);
        }

        return ans;
    }
}
```

