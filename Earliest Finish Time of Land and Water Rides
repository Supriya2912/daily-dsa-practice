# 🐍 Python Solution

```python
class Solution:
    def earliestFinishTime(self, lst, ldu, wst, wdu):

        min_land = min(
            lst[i] + ldu[i]
            for i in range(len(lst))
        )

        ans = float('inf')

        # Land -> Water
        for i in range(len(wst)):
            ans = min(
                ans,
                max(min_land, wst[i]) + wdu[i]
            )

        min_water = min(
            wst[i] + wdu[i]
            for i in range(len(wst))
        )

        # Water -> Land
        for i in range(len(lst)):
            ans = min(
                ans,
                max(min_water, lst[i]) + ldu[i]
            )

        return ans
```

