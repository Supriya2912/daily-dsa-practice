# ✅ C++ Solution

```cpp
class Solution {
public:
    int earliestFinishTime(vector<int>& lst, vector<int>& ldu,
                           vector<int>& wst, vector<int>& wdu) {

        int ans = INT_MAX;
        int mln = INT_MAX;
        int mnw = INT_MAX;

        // Earliest finishing land ride
        for (int i = 0; i < lst.size(); i++)
            mln = min(mln, lst[i] + ldu[i]);

        // Land -> Water
        for (int i = 0; i < wst.size(); i++)
            ans = min(ans,
                      max(mln, wst[i]) + wdu[i]);

        // Earliest finishing water ride
        for (int i = 0; i < wst.size(); i++)
            mnw = min(mnw, wst[i] + wdu[i]);

        // Water -> Land
        for (int i = 0; i < lst.size(); i++)
            ans = min(ans,
                      max(mnw, lst[i]) + ldu[i]);

        return ans;
    }
};
```

