# 🐍 Python Solution

```python
class Solution:
    def earliestFinishTime(
        self,
        landStartTime,
        landDuration,
        waterStartTime,
        waterDuration
    ):

        min_land_end = min(
            s + d
            for s, d in zip(landStartTime, landDuration)
        )

        min_water_end = min(
            s + d
            for s, d in zip(waterStartTime, waterDuration)
        )

        ans = float('inf')

        # Land -> Water
        for s, d in zip(waterStartTime, waterDuration):

            if s < min_land_end:
                ans = min(ans, min_land_end + d)
            else:
                ans = min(ans, s + d)

        # Water -> Land
        for s, d in zip(landStartTime, landDuration):

            if s < min_water_end:
                ans = min(ans, min_water_end + d)
            else:
                ans = min(ans, s + d)

        return ans
```

